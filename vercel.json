{
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.5.15"
    }
  },
  "rewrites": [
    { "source": "/api/admin", "destination": "/api/misc/admin" },
    { "source": "/api/admin/(.*)", "destination": "/api/misc/admin/$1" },
    { "source": "/api/profile", "destination": "/api/misc/profile" },
    { "source": "/api/profile/(.*)", "destination": "/api/misc/profile/$1" },
    { "source": "/api/memberships", "destination": "/api/misc/memberships" },
    { "source": "/api/memberships/(.*)", "destination": "/api/misc/memberships/$1" },
    { "source": "/api/event-registrations", "destination": "/api/misc/event-registrations" },
    { "source": "/api/event-registrations/(.*)", "destination": "/api/misc/event-registrations/$1" },
    { "source": "/api/members", "destination": "/api/misc/members" },
    { "source": "/api/members/(.*)", "destination": "/api/misc/members/$1" },
    { "source": "/api/zones", "destination": "/api/misc/zones" },
    { "source": "/api/zones/(.*)", "destination": "/api/misc/zones/$1" },
    { "source": "/api/tiers", "destination": "/api/misc/tiers" },
    { "source": "/api/tiers/(.*)", "destination": "/api/misc/tiers/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
