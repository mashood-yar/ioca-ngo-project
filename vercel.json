{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.5.15",
      "excludeFiles": "api/_lib/**"
    }
  },
  "rewrites": [
    { "source": "/api/upload(.*)", "destination": "/api/misc/upload$1" },
    { "source": "/api/applications(.*)", "destination": "/api/misc/applications$1" },
    { "source": "/api/zones(.*)", "destination": "/api/misc/zones$1" },
    { "source": "/api/tiers(.*)", "destination": "/api/misc/tiers$1" },
    { "source": "/api/members(.*)", "destination": "/api/misc/members$1" },
    { "source": "/api/profile(.*)", "destination": "/api/misc/profile$1" },
    { "source": "/api/memberships(.*)", "destination": "/api/misc/memberships$1" },
    { "source": "/api/event-registrations(.*)", "destination": "/api/misc/event-registrations$1" },
    { "source": "/api/admin/applications(.*)", "destination": "/api/misc/admin/applications$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
