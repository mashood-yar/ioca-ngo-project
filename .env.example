# Supabase Config
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database Connections (PostgreSQL direct/pooler)
DATABASE_URL=postgresql://postgres:password@your-project-pooler:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@your-project-direct:5432/postgres

# Resend Email Config
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Vercel Configuration
CLIENT_URL=http://localhost:3000
PORT=3000

# Frontend environment config (Vite reads from VITE_ prefixed variables)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=http://localhost:3000
